# ════════════════════════════════════════════════════════════════════
# Nepali Legal QA — Backend Environment Variables
# ════════════════════════════════════════════════════════════════════
# In Google Colab: set these via Colab Secrets, then read with:
#   from google.colab import userdata
#   os.environ["GROQ_API_KEY"] = userdata.get("GROQ_API_KEY")
#
# For local testing: copy this file to .env and fill in values.
# ════════════════════════════════════════════════════════════════════

# ─ Groq API Keys ────────────────────────────────────────────────────
# 4 keys for round-robin rate-limit headroom (same as nepali_rag_qa.ipynb)
# Get free keys at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here
GROQ_API_KEY_4=your_groq_api_key_4_here

# ─ Model ────────────────────────────────────────────────────────────
# Fine-tuned Qwen2.5-1.5B SLM used for HyDE generation only
MODEL_ID=zeri000/nepali_legal_qwen_merged_4

# ─ Documents ────────────────────────────────────────────────────────
# Path to the legal text file used to build the FAISS index
# In Colab this file is at /content/augmented_nepali_legal_rag.txt
# Upload it to Colab before running the server
DOC_FILE_PATH=/content/augmented_nepali_legal_rag.txt

# ─ Notes ────────────────────────────────────────────────────────────
# - The SLM (MODEL_ID) is only used for HyDE generation (local inference).
# - Answer generation uses Groq llama-3.3-70b-versatile (remote API).
# - augmented_nepali_legal_rag.txt must be uploaded to Colab manually
#   (it is not in the GitHub repo due to size).
# ════════════════════════════════════════════════════════════════════
