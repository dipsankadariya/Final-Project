# ────────────────────────────────────────────────────────────────
# Nepali Legal QA — Frontend Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy this file to .env and set VITE_API_BASE to the public URL
# printed by ngrok when you run the Colab backend notebook.
#
# Example (ngrok URL — changes each time Colab restarts):
# VITE_API_BASE=https://xxxx-xxxx.ngrok-free.app
#
# The Vite dev server proxies all /api/* requests to this URL,
# so CORS and ngrok warnings are handled automatically.
# ────────────────────────────────────────────────────────────────
VITE_API_BASE=https://your-ngrok-url-here.ngrok-free.app
